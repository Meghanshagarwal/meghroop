# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Admin ────────────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-password-here
ADMIN_JWT_SECRET=a-long-random-secret-at-least-32-chars

# Encrypts the admin Credentials vault (AES-256-GCM) before it is written to
# Supabase, so a DB dump never exposes stored passwords/secrets in plain text.
# Use a long random value. If unset, credentials fall back to plaintext storage.
# Generate: openssl rand -base64 32
CREDENTIALS_SECRET=a-long-random-secret-at-least-32-chars

# ─── Journal Auto-Publish API (used by n8n) ───────────────────
# Bearer token n8n sends to POST /api/journal. Keep it long & secret.
JOURNAL_API_KEY=a-long-random-secret-for-journal-publishing

# ─── Analytics (fallback if not set in Supabase settings) ─────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ─── WhatsApp ─────────────────────────────────────────────────
# Country code + number, no + or spaces (e.g. 918949508264)
NEXT_PUBLIC_WHATSAPP_NUMBER=918949508264

# ─── SEO Checker — Gemini report engine ───────────────────────
# Free key from https://aistudio.google.com (format: AIza...).
# Can also be set/changed from Admin → SEO Audits (stored in the settings table,
# which overrides this env var). Requires the seo_audits table — see
# docs/seo-audits-table.sql.
GEMINI_API_KEY=AIza-your-key-here

# ─── Email Notifications (Gmail App Password) ─────────────────
EMAIL_USER=your@gmail.com
# Generate at: Google Account → Security → App Passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=your@gmail.com

# ─── Google Sheets Integration ────────────────────────────────
# 1. Open https://script.google.com → New Project
# 2. Paste the script from /docs/google-apps-script.js
# 3. Deploy → New deployment → Web app → Execute as: Me → Anyone
# 4. Copy the web app URL here
GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec
